{
  "info": {
    "name": "Shop Demo API",
    "_postman_id": "shop-demo-collection",
    "description": "API tests for shop demo project",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://127.0.0.1:3000"
    }
  ],
  "item": [
    {
      "name": "GET /products",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/api/products"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Статус 200', function () {pm.response.to.have.status(200);});",
              "const productsData = pm.response.json();",
              "pm.test('Массив товаров', () => pm.expect(productsData).to.be.an('array'));",
              "pm.test('6 товаров', () => pm.expect(productsData.length).to.eql(6));"
            ]
          }
        }
      ]
    },
    {
      "name": "GET /cart",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/api/cart"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Статус 200', () => pm.response.to.have.status(200));",
              "pm.test('Корзина массив', () => pm.expect(pm.response.json()).to.be.an('array'));"
            ]
          }
        }
      ]
    },
    {
      "name": "POST /cart add product",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"productId\": 1\n}"
        },
        "url": "{{baseUrl}}/api/cart"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Статус 200', () => pm.response.to.have.status(200));",
              "const cartData = pm.response.json();",
              "pm.test('Товар добавлен', () => pm.expect(cartData .length).to.be.above(0));"
            ]
          }
        }
      ]
    },
    {
      "name": "POST /cart invalid id",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"productId\": 999\n}"
        },
        "url": "{{baseUrl}}/api/cart"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Статус 404', () => pm.response.to.have.status(404));",
              "pm.test('Ошибка', () => pm.expect(pm.response.json().error).to.eql('Товар не найден'));"
            ]
          }
        }
      ]
    },
    {
      "name": "PUT /cart change quantity",
      "request": {
        "method": "PUT",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"quantity\": 5\n}"
        },
        "url": "{{baseUrl}}/api/cart/1"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Статус 200', () => pm.response.to.have.status(200));"
            ]
          }
        }
      ]
    },
    {
      "name": "PUT /cart invalid quantity",
      "request": {
        "method": "PUT",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"quantity\": 0\n}"
        },
        "url": "{{baseUrl}}/api/cart/1"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Статус 400', () => pm.response.to.have.status(400));"
            ]
          }
        }
      ]
    },
    {
      "name": "DELETE /cart",
      "request": {
        "method": "DELETE",
        "url": "{{baseUrl}}/api/cart/1"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Статус 200', () => pm.response.to.have.status(200));"
            ]
          }
        }
      ]
    },
    {
      "name": "POST /order success",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Иван\",\n  \"phone\": \"89990001122\",\n  \"address\": \"Москва\"\n}"
        },
        "url": "{{baseUrl}}/api/order"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Статус 200', () => pm.response.to.have.status(200));",
              "pm.test('Успешный заказ', () => pm.expect(pm.response.json().message).to.eql('Заказ оформлен'));"
            ]
          }
        }
      ]
    },
    {
      "name": "POST /order no phone",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Иван\",\n  \"phone\": \"\",\n  \"address\": \"Москва\"\n}"
        },
        "url": "{{baseUrl}}/api/order"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Статус 400', () => pm.response.to.have.status(400));",
              "pm.test('Ошибка телефона', () => pm.expect(pm.response.json().error).to.eql('Телефон обязателен'));"
            ]
          }
        }
      ]
    }
  ]
}